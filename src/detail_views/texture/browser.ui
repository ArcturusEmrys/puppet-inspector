<?xml version="1.0" encoding="UTF-8" ?>
<interface>
    <template class="PIPuppetTextureBrowser" parent="GtkBox">
        <property name="hexpand">true</property>
        <property name="vexpand">true</property>
        <property name="orientation">vertical</property>
        <child>
            <object class="GtkScrolledWindow">
                <child>
                    <object class="GtkGridView" id="texture_view">
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                        <property name="model">
                            <object class="GtkSingleSelection" id="texture_selection">
                            </object>
                        </property>
                        <property name="factory">
                            <object class="GtkSignalListItemFactory" id="texture_factory">
                            </object>
                        </property>
                    </object>
                </child>
            </object>
        </child>
    </template>
</interface>